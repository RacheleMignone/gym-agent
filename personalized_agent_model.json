        "height": 30
      },
      "replyType": "text"
    },
    "6c0d04f1-698e-40ae-868d-5f9eb349ca2f": {
      "id": "6c0d04f1-698e-40ae-868d-5f9eb349ca2f",
      "name": "I stick to gym and fitness, nothing else.",
      "type": "AgentStateFallbackBody",
      "owner": "ea576a25-3d53-4c16-b8b3-362579ad7c84",
      "bounds": {
        "x": 210,
        "y": -80,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "0077e9dd-aa0b-4531-b35e-2735345e6a70": {
      "id": "0077e9dd-aa0b-4531-b35e-2735345e6a70",
      "name": "Prioritize the big, heavy lifts\u2014squats, deadlifts, bench press, overhead press, and rows. They\u2019re great for building muscle.",
      "type": "AgentStateBody",
      "owner": "00df012d-7731-435c-9113-bafe45eb5878",
      "bounds": {
        "x": -280,
        "y": 140,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "7865e98c-161a-44ec-a2f5-ff0042095f09": {
      "id": "7865e98c-161a-44ec-a2f5-ff0042095f09",
      "name": "Train 3-5 days a week. Keep adding a little weight over time. Eat enough protein and calories to grow.",
      "type": "AgentStateBody",
      "owner": "00df012d-7731-435c-9113-bafe45eb5878",
      "bounds": {
        "x": -280,
        "y": 140,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "5c82550f-8070-44f8-8e53-a9402feca3d7": {
      "id": "5c82550f-8070-44f8-8e53-a9402feca3d7",
      "name": "Get enough sleep and stay consistent. Muscle grows with steady work over time.",
      "type": "AgentStateBody",
      "owner": "00df012d-7731-435c-9113-bafe45eb5878",
      "bounds": {
        "x": -280,
        "y": 140,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "b64cd242-273a-4f73-935a-6b5938e24b31": {
      "id": "b64cd242-273a-4f73-935a-6b5938e24b31",
      "name": "Food basics: mostly whole foods\u2014lean protein, veggies, fruits, whole grains, and healthy fats. Aim for about 1.6 to 2.2 grams of protein per kilogram of body weight each day.",
      "type": "AgentStateBody",
      "owner": "3daca150-a9eb-4f86-8b93-c03cafbecc05",
      "bounds": {
        "x": 210,
        "y": 140,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "4c9ff0d6-4c8c-43ee-8489-9d09e9b8af43": {
      "id": "4c9ff0d6-4c8c-43ee-8489-9d09e9b8af43",
      "name": "Match your calories to your goal: eat a bit more to gain muscle, a bit less to lose fat, or about the same to maintain your weight.",
      "type": "AgentStateBody",
      "owner": "3daca150-a9eb-4f86-8b93-c03cafbecc05",
      "bounds": {
        "x": 210,
        "y": 140,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "a9207f59-1bbb-4917-b295-80ce539b5b65": {
      "id": "a9207f59-1bbb-4917-b295-80ce539b5b65",
      "name": "Carbs fuel your training. Fats support your hormones.",
      "type": "AgentStateBody",
      "owner": "3daca150-a9eb-4f86-8b93-c03cafbecc05",
      "bounds": {
        "x": 210,
        "y": 140,
        "width": 159,
        "height": 30
      },
      "replyType": "text"
    },
    "90b69353-dcdd-4bcf-97f2-e87234ed35e7": {
      "id": "90b69353-dcdd-4bcf-97f2-e87234ed35e7",
      "name": "Drink plenty of water. Keep ultra-processed foods and alcohol in check.",
      "type": "AgentStateBody",
      "owner": "3daca150-a9eb-4f86-8b93-c03cafbecc05",
      "bounds": {
        "x": 210,
        "y": 140,
