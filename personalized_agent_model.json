    "39ab555f-3be3-4678-8f7f-2c250be3df4b": {
      "id": "39ab555f-3be3-4678-8f7f-2c250be3df4b",
      "name": "Hey, I\u2019m your fitness coach.",
      "type": "AgentStateBody",
      "owner": "75033d15-c580-48da-ba4a-7dec33a14f58",
      "bounds": {
        "x": -280,
