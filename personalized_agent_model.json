    "6a9f5592-3f4f-450f-8cb2-1a24aad38652": {
      "id": "6a9f5592-3f4f-450f-8cb2-1a24aad38652",
      "name": "I can answer your questions about workouts, nutrition, and recovery.",
      "type": "AgentStateBody",
      "owner": "ea576a25-3d53-4c16-b8b3-362579ad7c84",
      "bounds": {
        "x": 210,
        "y": -80,
